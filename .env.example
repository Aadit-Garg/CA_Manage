# ──────────────────────────────────────────────
# CA Manage — Environment Variables
# Copy this file to .env and fill in values
# ──────────────────────────────────────────────

# Flask
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=change-this-to-a-long-random-string

# Database (NeonDB PostgreSQL or local SQLite fallback)
# PostgreSQL: postgresql://user:password@host:5432/dbname?sslmode=require
# SQLite:     sqlite:///ca_manage.db
DATABASE_URL=sqlite:///ca_manage.db

# Cloudinary (PDF storage — configure when ready)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Rate Limiting
RATELIMIT_STORAGE_URI=memory://
RATELIMIT_DEFAULT=200 per hour

# Session
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# Admin Seed
ADMIN_EMAIL=admin@camanage.com
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=System Administrator
